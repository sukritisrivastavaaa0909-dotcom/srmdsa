class Solution {
public:
    vector<vector<int>> ans;
    vector<int> temp;

    void dfs(vector<int>& c, int target, int i) {
        if (target == 0) {
            ans.push_back(temp);
            return;
        }

        if (i == c.size() || target < 0) return;

        temp.push_back(c[i]);
        dfs(c, target - c[i], i);   
        temp.pop_back();

        dfs(c, target, i + 1);      
    }

    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        dfs(candidates, target, 0);
        return ans;
    }
};
